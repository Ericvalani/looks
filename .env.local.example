# Copie este arquivo para .env.local e preencha com os valores reais.
# NUNCA coloque valores reais aqui — este arquivo é versionado no git.

# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Portão de acesso ao app
APP_GATE_PASSWORD=uma-senha-de-entrada
# string aleatória longa, ex: openssl rand -hex 32
APP_GATE_SECRET=troque-por-uma-string-aleatoria-longa

# Contas fixas (criadas pelo script "npm run seed")
ERIC_EMAIL=eric@internal.app
ERIC_PASSWORD=defina-uma-senha
MATEUS_EMAIL=mateus@internal.app
MATEUS_PASSWORD=defina-uma-senha

# OpenAI (gpt-image-2)
OPENAI_API_KEY=sk-proj-sua-chave-openai
